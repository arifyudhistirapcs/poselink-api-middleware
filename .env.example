# ===========================================
# Payment Middleware - Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values

# Ably Configuration (REQUIRED)
ABLY_API_KEY=your_ably_api_key_here

# Encryption Configuration
# Shared secret between middleware and EDC for AES-128-ECB encryption
ENCRYPTION_SECRET=ECR2022secretKey

# Server Configuration
SERVER_PORT=8080
TIMEOUT_DURATION=60

# MID/TID to Serial Number Mappings (JSON format)
# Used for initial migration to Redis via POST /api/v1/admin/migrate
# Format: {"MID:TID":"SerialNumber"}
MIDTID_MAPPINGS={"1234567890:99887766":"DEVICE_SERIAL_001"}

# Redis Configuration (REQUIRED)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MIN_IDLE_CONNS=5
REDIS_MAX_CONNS=100
