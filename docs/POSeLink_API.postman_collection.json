{
	"info": {
		"_postman_id": "poselink-api-collection",
		"name": "POSeLink API",
		"description": "API Collection untuk POSeLink Middleware - Payment Gateway EDC Integration.\n\nCollection ini sudah dilengkapi dengan:\n- Auto-enkripsi token (AES-128-ECB) via pre-request script\n- Auto-generate trx_id\n- Auto-generate timestamp\n\n**Setup:**\n1. Set variable `base_url` sesuai environment\n2. Set variable `mid` dan `tid` sesuai device\n3. Jalankan request langsung",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "https://development-ecrlink.pcsindonesia.com",
			"type": "string"
		},
		{
			"key": "mid",
			"value": "1999115921",
			"type": "string"
		},
		{
			"key": "tid",
			"value": "10747686",
			"type": "string"
		},
		{
			"key": "encryption_secret",
			"value": "ECR2022secretKey",
			"type": "string"
		},
		{
			"key": "trx_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Transaction",
			"description": "Endpoint untuk mengirim dan mengecek transaksi pembayaran.",
			"item": [
				{
					"name": "Sale - Purchase (Kartu)",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"// Auto-generate trx_id dan timestamp",
									"const trxId = 'TXN' + Date.now().toString(36).toUpperCase() + Math.random().toString(36).substring(2, 6).toUpperCase();",
									"const now = new Date();",
									"const pad = (n) => n.toString().padStart(2, '0');",
									"const timestamp = `${now.getFullYear()}-${pad(now.getMonth()+1)}-${pad(now.getDate())} ${pad(now.getHours())}:${pad(now.getMinutes())}:${pad(now.getSeconds())}`;",
									"",
									"pm.collectionVariables.set('trx_id', trxId);",
									"",
									"// Build transaction data",
									"const transaction = {",
									"    amount: pm.variables.get('amount') || '1',",
									"    action: 'Sale',",
									"    trx_id: trxId,",
									"    pos_address: '192.10.10.10',",
									"    time_stamp: timestamp,",
									"    method: 'purchase'",
									"};",
									"",
									"// AES-128-ECB encryption",
									"const secret = pm.collectionVariables.get('encryption_secret');",
									"const sha1Hex = CryptoJS.SHA1(secret).toString(CryptoJS.enc.Hex);",
									"const keyHex = sha1Hex.substring(0, 32);",
									"const key = CryptoJS.enc.Hex.parse(keyHex);",
									"const encrypted = CryptoJS.AES.encrypt(",
									"    JSON.stringify(transaction),",
									"    key,",
									"    { mode: CryptoJS.mode.ECB, padding: CryptoJS.pad.Pkcs7 }",
									");",
									"",
									"pm.collectionVariables.set('token', encrypted.toString());",
									"console.log('Transaction:', JSON.stringify(transaction));",
									"console.log('TrxID:', trxId);"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"token\": \"{{token}}\",\n  \"mid\": \"{{mid}}\",\n  \"tid\": \"{{tid}}\",\n  \"trx_id\": \"{{trx_id}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/transaction",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "transaction"]
						},
						"description": "Transaksi Sale dengan metode purchase (kartu debit/kredit).\n\nAmount default: 1 (set variable `amount` untuk mengubah)."
					},
					"response": []
				},
